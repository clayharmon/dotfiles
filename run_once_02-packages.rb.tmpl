#!/usr/bin/env ruby
# Step 2: Install all CLI tools and applications

def run(cmd)
  puts "=> #{cmd}"
  system(cmd) || abort("Failed: #{cmd}")
end

def brew(*pkgs)
  run "brew install #{pkgs.join(" ")}"
end

def cask(*pkgs)
  run "brew install --cask #{pkgs.join(" ")}"
end

def pacman(*pkgs)
  run "sudo pacman -S --needed --noconfirm #{pkgs.join(" ")}"
end

def dnf(*pkgs)
  run "sudo dnf install -y #{pkgs.join(" ")}"
end

{{ if eq .chezmoi.os "darwin" -}}
cli_tools = %w[
  neovim fish tmux starship eza bat fd ripgrep
  zoxide atuin git-delta sd xh dust fzf jq
  lazygit gh aichat
]

apps = %w[
  ghostty firefox@developer-edition aerospace
  karabiner-elements docker bitwarden spotify
  font-jetbrains-mono-nerd-font
]

puts "Installing CLI tools..."
brew(*cli_tools)

puts "Installing apps..."
cask(*apps)

puts "Installing macOS bar + borders..."
run "brew tap FelixKratz/formulae"
brew("sketchybar", "borders")

puts "Installing Claude Code CLI..."
run "npm install -g @anthropic-ai/claude-code"

{{ else if eq .chezmoi.os "linux" -}}
def yay(*pkgs)
  run "yay -S --needed --noconfirm #{pkgs.join(" ")}"
end

def cargo_install(*pkgs)
  pkgs.each { |pkg| run "cargo install #{pkg}" }
end

if system("command -v pacman &>/dev/null")
  packages = %w[
    neovim fish tmux starship eza bat fd ripgrep
    zoxide atuin git-delta sd xh dust fzf jq
    lazygit docker chromium github-cli ghostty aichat
    ttf-jetbrains-mono-nerd
  ]
  puts "Installing packages (Arch)..."
  pacman(*packages)

  # Install yay if not present
  unless system("command -v yay &>/dev/null")
    puts "Installing yay..."
    run "sudo pacman -S --needed --noconfirm git base-devel"
    run "git clone https://aur.archlinux.org/yay.git /tmp/yay && cd /tmp/yay && makepkg -si --noconfirm && rm -rf /tmp/yay"
  end

  # AUR packages
  puts "Installing AUR packages..."
  yay("spotify", "firefox-developer-edition")

elsif system("command -v dnf &>/dev/null")
  # Packages available in default Fedora repos
  repo_packages = %w[
    neovim fish tmux eza bat fd-find ripgrep
    zoxide atuin git-delta sd du-dust fzf jq
    gh chromium jetbrains-mono-fonts-all
  ]
  puts "Installing repo packages (Fedora)..."
  dnf(*repo_packages)

  # Copr repos for packages not in default repos
  puts "Enabling Copr repos..."
  run "sudo dnf copr enable -y atim/starship"
  run "sudo dnf copr enable -y atim/lazygit"
  run "sudo dnf copr enable -y pgdev/ghostty"

  puts "Installing Copr packages..."
  dnf("starship", "lazygit", "ghostty")

  # Docker CE
  puts "Installing Docker CE..."
  run "sudo dnf config-manager addrepo --from-repofile=https://download.docker.com/linux/fedora/docker-ce.repo"
  dnf("docker-ce", "docker-ce-cli", "containerd.io", "docker-buildx-plugin", "docker-compose-plugin")

  # Spotify via negativo17 repo
  puts "Installing Spotify..."
  run "sudo dnf config-manager --add-repo=https://negativo17.org/repos/fedora-spotify.repo"
  dnf("spotify-client")

  # Firefox Developer Edition via Copr
  puts "Installing Firefox Developer Edition..."
  run "sudo dnf copr enable -y the4runner/firefox-dev"
  dnf("firefox-developer-edition")

  # Tools not packaged for Fedora -- install via cargo
  puts "Installing cargo packages (xh, aichat)..."
  cargo_install("xh", "aichat")
end

# Claude Code CLI (npm -- available after mise installs node in step 01)
puts "Installing Claude Code CLI..."
run "npm install -g @anthropic-ai/claude-code"

{{ end -}}
puts "Packages installed!"
