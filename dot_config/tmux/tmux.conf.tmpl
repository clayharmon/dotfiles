# Dracula-themed minimal tmux config

# ── General ────────────────────────────────────────────────────────
set -g default-terminal "tmux-256color"
set -ag terminal-overrides ",xterm-256color:RGB"
set -ag terminal-features ",xterm-256color:hyperlinks"
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g escape-time 0
set -g history-limit 50000
set -g focus-events on
set -g set-clipboard on

# ── Prefix ─────────────────────────────────────────────────────────
unbind C-b
set -g prefix C-a
bind C-a send-prefix

# ── Splits (vim-style) ────────────────────────────────────────────
bind v split-window -h -c "#{pane_current_path}"
bind s split-window -v -c "#{pane_current_path}"
bind c new-window -c "#{pane_current_path}"

# ── Navigation (vim-style) ────────────────────────────────────────
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# ── Resize (vim-style) ────────────────────────────────────────────
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# ── Layouts ───────────────────────────────────────────────────────
bind Space next-layout
bind e select-layout even-horizontal
bind E select-layout even-vertical
bind m select-layout main-vertical
bind M select-layout main-horizontal

# ── Swap/reposition panes ─────────────────────────────────────────
bind > swap-pane -D
bind < swap-pane -U
bind Enter swap-pane -s '{top-left}' \; select-pane -t '{top-left}'

# ── Copy mode (vi) ────────────────────────────────────────────────
setw -g mode-keys vi
bind -T copy-mode-vi v send -X begin-selection
{{- if eq .chezmoi.os "darwin" }}
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "pbcopy"
{{- else }}
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "wl-copy"
{{- end }}

# ── Fuzzy finders (fzf + bat popups) ──────────────────────────────
FZF_DRACULA="--color='bg:#282a36,fg:#f8f8f2,hl:#bd93f9,bg+:#44475a,fg+:#f8f8f2,hl+:#ff79c6,info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6,marker:#ff79c6,spinner:#ffb86c,header:#6272a4'"

# Find files -> open in nvim
bind f display-popup -E -w 80% -h 80% -b rounded -S "fg=#bd93f9" \
  "fd --type f --hidden --follow --exclude .git --exclude node_modules --exclude .cache --exclude Library --exclude .local . $HOME | \
   fzf --preview 'bat --color=always --style=numbers --line-range=:200 {}' \
       --preview-window=right:50% \
       --header 'find files' \
       --color='bg:#282a36,fg:#f8f8f2,hl:#bd93f9,bg+:#44475a,fg+:#f8f8f2,hl+:#ff79c6,info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6,marker:#ff79c6,spinner:#ffb86c,header:#6272a4' \
   | xargs -I{} tmux new-window nvim {}"

# Grep content -> open in nvim at line (starts empty, searches as you type)
bind g display-popup -E -w 80% -h 80% -b rounded -S "fg=#bd93f9" \
  "fzf --bind 'start:reload:true' \
       --bind 'change:reload:rg --color=always --line-number --no-heading --smart-case --hidden --glob !.git --glob !node_modules --glob !.cache --glob !Library --glob !.local {q} || true' \
       --phony --ansi --delimiter : \
       --preview 'bat --color=always --style=numbers --highlight-line {2} {1}' \
       --preview-window=right:50% \
       --color='bg:#282a36,fg:#f8f8f2,hl:#bd93f9,bg+:#44475a,fg+:#f8f8f2,hl+:#ff79c6,info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6,marker:#ff79c6,spinner:#ffb86c,header:#6272a4' \
   | awk -F: '{print \"+\" $2 \" \" $1}' | xargs tmux new-window nvim"

# App launcher
bind a display-popup -E -w 50% -h 50% -b rounded -S "fg=#bd93f9" \
  "ls /Applications /Applications/Utilities /System/Applications 2>/dev/null | \
   grep '\\.app$' | sed 's/\\.app$//' | sort -u | \
   fzf --color='bg:#282a36,fg:#f8f8f2,hl:#bd93f9,bg+:#44475a,fg+:#f8f8f2,hl+:#ff79c6,info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6,marker:#ff79c6,spinner:#ffb86c,header:#6272a4' \
   | xargs -I{} open -a '{}'"

# ── Reload ─────────────────────────────────────────────────────────
bind r source-file ~/.config/tmux/tmux.conf \; display "Config reloaded"

# ── Dracula Theme ──────────────────────────────────────────────────
set -g status-style "bg=#282a36,fg=#f8f8f2"
set -g status-left "#[fg=#282a36,bg=#bd93f9,bold] #S #[fg=#bd93f9,bg=#282a36] "
set -g status-left-length 30
set -g status-right "#[fg=#6272a4]%a %d %b #[fg=#f8f8f2]%H:%M "
set -g status-right-length 40

# Window tabs
setw -g window-status-format "#[fg=#6272a4] #I:#W "
setw -g window-status-current-format "#[fg=#282a36,bg=#44475a,bold] #I:#W "

# Pane borders
set -g pane-border-style "fg=#44475a"
set -g pane-active-border-style "fg=#bd93f9"

# Message style
set -g message-style "bg=#44475a,fg=#f8f8f2"
set -g message-command-style "bg=#44475a,fg=#f8f8f2"

# Mode style (copy mode highlight)
setw -g mode-style "bg=#44475a,fg=#f8f8f2"

# ── Status bar position ───────────────────────────────────────────
set -g status-position bottom
