{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps lock to ctrl (held) / escape (tapped)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_control", "lazy": true }],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Open messages by left option + m",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "m",
                                    "modifiers": {
                                        "mandatory": ["left_option"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "software_function": { "open_application": { "file_path": "/System/Applications/Messages.app" } } }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Open firefox by left option + v",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "v",
                                    "modifiers": {
                                        "mandatory": ["left_option"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "software_function": { "open_application": { "file_path": "/Applications/Firefox Developer Edition.app" } } }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Launcher via cmd + space",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "spacebar",
                                    "modifiers": {
                                        "mandatory": ["command"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "key_code": "f19" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Open Ghostty by opt + return",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "return_or_enter",
                                    "modifiers": {
                                        "mandatory": ["left_option"],
                                        "optional": ["caps_lock"]
                                    }
                                },
                                "to": [{ "software_function": { "open_application": { "file_path": "/Applications/Ghostty.app" } } }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}